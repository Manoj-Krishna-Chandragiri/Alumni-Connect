# ============================================================
# LOCAL DEVELOPMENT
# ============================================================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite is used automatically when DATABASE_URL is not set (local dev)
# DATABASE_URL=   <-- leave unset for local SQLite

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/alumni_connect_db?retryWrites=true&w=majority

# JWT
JWT_SECRET_KEY=your-jwt-secret-key

# CORS (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# ============================================================
# EMAIL (Gmail via App Password recommended)
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=VVITU Alumni Network <your-email@gmail.com>

# For console output during local dev (no emails sent):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ============================================================
# CLOUDINARY (file/image uploads)
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================================
# PRODUCTION ONLY (set these in Render dashboard, not here)
# ============================================================
# DEBUG=False
# SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_urlsafe(50))">
# JWT_SECRET_KEY=<same as SECRET_KEY or separate>
# ALLOWED_HOSTS=your-app.onrender.com
# DATABASE_URL=postgresql://user:pass@host/dbname   <-- auto-set by Render postgres addon
# CORS_ALLOWED_ORIGINS=https://your-app.amplifyapp.com
# FRONTEND_URL=https://your-app.amplifyapp.com

